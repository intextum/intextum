# Local Docker Compose environment.
#
# Copy to .env and adjust local secrets:
#   cp .env.example .env

# Optional. The dev stack is reached at http://localhost:5173 (Vite) without it.
# Set it only when serving the app under a custom hostname (added to Vite's
# allowedHosts) or as a fallback base URL for a host-run worker.
APP_DOMAIN=

# Optional override for the repo-root VERSION file.
APP_VERSION=

# Optional UI branding.
APP_BRAND_TITLE=Intextum
APP_BRAND_SUBTITLE=

# Development Postgres container credentials.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=intextum_db

# Worker API token. Leave empty while the Compose worker is scaled to 0.
# Set a strong shared token before running a host or Compose worker.
WORKER_TOKEN=

# Supported capabilities: document,image,video,training
WORKER_CAPABILITIES=document,video,image
WORKER_POLL_INTERVAL=5

# Supported OCR engines: easyocr,rapidocr,tesseract,tesseract_cli,ocrmac
WORKER_DOCLING_OCR_ENGINE=easyocr

# Local auth bootstrap metadata. Set the bootstrap password in config.yaml.
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin

# Backend runtime settings passed by Compose.
VALKEY_URL=redis://valkey:6379/0
CHAT_RUNNER_ENABLED=true

# Required before storing encrypted connector secrets and in production-like runs.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
